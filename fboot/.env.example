# fboot (frontend) configuration. Copy to `.env` (or `.env.local`) and adjust.
# Vite only exposes vars prefixed with VITE_. Restart `pnpm dev` after changes.

# --- Dev only: where the Vite dev server proxies /api and /ws ---
# This is the simplest knob: point the dev proxy at your fbootd instance.
# The app keeps using same-origin /api + /ws, so no CORS is involved.
VITE_BACKEND_URL=http://localhost:8080

# --- Production / direct (no proxy): talk to an absolute backend ---
# Set these when serving the built app from a different origin than fbootd
# (fbootd enables permissive CORS). Leave unset to use the same-origin defaults
# (/api and same-host websockets), which is what you want behind a reverse proxy.
# VITE_API_BASE=https://fbootd.example.com/api
# VITE_WS_BASE=https://fbootd.example.com
