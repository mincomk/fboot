# fbootd configuration — copy to `.env` and adjust. All values shown are the defaults.
# Loaded via dotenvy at startup; real environment variables override the .env file.
#
# A TOML config file can also be used via CONFIG_PATH (default /etc/fbootd.toml).
# See fbootd.toml.example. Environment variables (including these) override the
# TOML file values.

# --- Logging ---
# tracing EnvFilter directive (logs go to stderr)
RUST_LOG=info,fbootd=debug

# --- Storage ---
# SQLite database path (created if missing)
FBOOTD_DB=fbootd.db
# Directory for uploaded bootable image blobs (created if missing)
FBOOTD_BLOB_DIR=blobs

# --- Advertised address ---
# IP advertised to PXE clients as next-server (TFTP) and embedded in iPXE script URLs.
# MUST be set to this host's LAN IP for real PXE boot; 0.0.0.0 only works for local tests.
FBOOTD_ADVERTISE_IP=0.0.0.0

# --- Listen addresses ---
# JSON/WebSocket API (dashboard + clients)
FBOOTD_API_ADDR=0.0.0.0:8080
# HTTP boot server (iPXE scripts + kernel/initrd blobs)
FBOOTD_HTTP_BOOT_ADDR=0.0.0.0:8081
# TFTP server (PXE boot program). Port 69 needs CAP_NET_BIND_SERVICE / root.
FBOOTD_TFTP_ADDR=0.0.0.0:69
# ProxyDHCP. Ports 67/4011 need CAP_NET_BIND_SERVICE / root.
FBOOTD_DHCP_ADDR=0.0.0.0:67
FBOOTD_DHCP_PROXY_ADDR=0.0.0.0:4011

# --- IPMI (ipmitool subprocess) ---
# Default credentials, overridable per-server via the API.
FBOOTD_IPMI_USER=admin
FBOOTD_IPMI_PASS=admin
# lanplus cipher suite (-C)
FBOOTD_IPMI_CIPHER=3
# Use the in-memory mock IPMI controller instead of ipmitool (dev/CI). 1/true to enable.
FBOOTD_IPMI_MOCK=false

# --- Background task intervals (seconds) ---
FBOOTD_STATUS_INTERVAL=1
FBOOTD_STATS_INTERVAL=1
FBOOTD_ARP_INTERVAL=5

# --- MCP server ---
# If set, serve the MCP streamable-HTTP transport on this address.
# FBOOTD_MCP_HTTP_ADDR=0.0.0.0:8090
# Set to 1/true to run as an MCP stdio server instead of the HTTP API (for MCP clients).
# FBOOTD_MCP_STDIO=0
